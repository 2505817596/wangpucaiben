        }
    </article>
</section>

@code {
    private decimal todayIncome;
    private decimal sevenDayIncome;
    private decimal thirtyDayIncome;
    private decimal todayProfit;
    private decimal sevenDayProfit;
    private decimal thirtyDayProfit;
    private List<ProductSalesRanking> sevenDayTopProducts = [];
    private List<ProductSalesRanking> thirtyDayTopProducts = [];
    private List<ProductSalesRanking> sevenDayTopProfitProducts = [];
    private List<ProductSalesRanking> thirtyDayTopProfitProducts = [];
    private ChartModel salesChart = ChartModel.Empty;
    private ChartModel profitChart = ChartModel.Empty;

    protected override void OnInitialized()
    {
        var now = DateTimeOffset.Now;
        var todayStart = new DateTimeOffset(now.Year, now.Month, now.Day, 0, 0, 0, now.Offset);
        var tomorrowStart = todayStart.AddDays(1);
        var sevenDayStart = todayStart.AddDays(-6);
        var thirtyDayStart = todayStart.AddDays(-29);

        todayIncome = TransactionService.GetIncomeTotal(todayStart, tomorrowStart);
        sevenDayIncome = TransactionService.GetIncomeTotal(sevenDayStart, tomorrowStart);
        thirtyDayIncome = TransactionService.GetIncomeTotal(thirtyDayStart, tomorrowStart);
        todayProfit = OrderService.GetProfitTotal(todayStart, tomorrowStart);
        sevenDayProfit = OrderService.GetProfitTotal(sevenDayStart, tomorrowStart);
        thirtyDayProfit = OrderService.GetProfitTotal(thirtyDayStart, tomorrowStart);
        sevenDayTopProducts = OrderService.GetTopSellingProducts(sevenDayStart, tomorrowStart);
        thirtyDayTopProducts = OrderService.GetTopSellingProducts(thirtyDayStart, tomorrowStart);
        sevenDayTopProfitProducts = OrderService.GetTopProfitProducts(sevenDayStart, tomorrowStart);
        thirtyDayTopProfitProducts = OrderService.GetTopProfitProducts(thirtyDayStart, tomorrowStart);
        salesChart = BuildChart(TransactionService.GetDailyIncomeSeries(thirtyDayStart, tomorrowStart), "销售额");
        profitChart = BuildChart(OrderService.GetDailyProfitSeries(thirtyDayStart, tomorrowStart), "纯利润");
    }

    private static ChartModel BuildChart(List<DailySalesPoint> points, string metricName)
    {
        if (points.Count == 0 || !points.Any(x => x.Amount > 0))
        {
            return ChartModel.Empty;
        }

        const decimal left = 48m;
        const decimal top = 24m;
        const decimal width = 640m;
        const decimal height = 196m;
        var maxAmount = points.Max(x => x.Amount);
        var scaleMax = maxAmount <= 0 ? 1m : maxAmount;
        var xStep = points.Count > 1 ? width / (points.Count - 1) : 0m;
        var baselineY = top + height;
        var linePointList = new List<string>();
        var dots = new List<ChartDot>();

        for (var i = 0; i < points.Count; i++)
        {
            var point = points[i];
            var x = left + (xStep * i);
            var y = baselineY - ((point.Amount / scaleMax) * height);
            linePointList.Add($"{FormatNumber(x)},{FormatNumber(y)}");

            if (point.Amount > 0)
            {
                dots.Add(new ChartDot
                {
                    X = x,
                    Y = y,
                    Label = $"{point.Date:MM-dd} {metricName} {FormatCurrency(point.Amount)}"
                });
            }
        }

        var linePoints = string.Join(" ", linePointList);
        var labelIndexes = BuildDateLabelIndexes(points.Count);

        return new ChartModel
        {
            HasData = true,
            MaxAmount = maxAmount,
            LinePoints = linePoints,
            AreaPoints = $"{FormatNumber(left)},{FormatNumber(baselineY)} {linePoints} {FormatNumber(left + width)},{FormatNumber(baselineY)}",
            Dots = dots,
            Guides =
            [
                CreateGuide(baselineY, 0m),
                CreateGuide(top + (height * 2m / 3m), scaleMax / 3m),
                CreateGuide(top + (height / 3m), scaleMax * 2m / 3m),
                CreateGuide(top, scaleMax)
            ],
            DateLabels = labelIndexes
                .Select(index => new ChartDateLabel
                {
                    X = left + (xStep * index),
                    Text = points[index].Date.ToString("MM-dd"),
                    Anchor = index == 0 ? "start" : index == points.Count - 1 ? "end" : "middle"
                })
                .ToList()
        };
    }

    private static ChartGuide CreateGuide(decimal y, decimal amount)
    {
        return new ChartGuide
        {
            Y = y,
            AmountText = FormatCurrency(amount)
        };
    }

    private static string FormatNumber(decimal value)
    {
        return value.ToString("0.##", CultureInfo.InvariantCulture);
    }

    private static string FormatCurrency(decimal value)
    {
        return $"¥{value.ToString("0.##", CultureInfo.InvariantCulture)}";
    }

    private static List<int> BuildDateLabelIndexes(int count)
    {
        if (count <= 1)
        {
            return [0];
        }

        var indexes = new HashSet<int> { 0, count - 1 };
        var segments = Math.Min(4, count - 1);

        for (var i = 1; i < segments; i++)
        {
            var index = (int)Math.Round((count - 1d) * i / segments, MidpointRounding.AwayFromZero);
            indexes.Add(index);
        }

        return indexes.OrderBy(x => x).ToList();
    }

    private sealed class ChartModel
    {
        public static readonly ChartModel Empty = new();

        public bool HasData { get; set; }

        public decimal MaxAmount { get; set; }

        public string LinePoints { get; set; } = string.Empty;

        public string AreaPoints { get; set; } = string.Empty;

        public List<ChartDot> Dots { get; set; } = [];

        public List<ChartGuide> Guides { get; set; } = [];

        public List<ChartDateLabel> DateLabels { get; set; } = [];
    }

    private sealed class ChartDot
    {
        public decimal X { get; set; }

        public decimal Y { get; set; }

        public string Label { get; set; } = string.Empty;
    }

    private sealed class ChartGuide
    {
        public decimal Y { get; set; }

        public string AmountText { get; set; } = string.Empty;
    }

    private sealed class ChartDateLabel
    {
        public decimal X { get; set; }

        public string Text { get; set; } = string.Empty;

        public string Anchor { get; set; } = "middle";
    }
}
