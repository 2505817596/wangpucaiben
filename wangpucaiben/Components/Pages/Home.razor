@page "/"
@using System.Globalization
@inject TransactionService TransactionService
@inject OrderService OrderService

<PageTitle>总览</PageTitle>

<section class="hero">
    <div>
        <p class="eyebrow">经营概览</p>
        <h1>先看收入，再看利润和热卖商品。</h1>
        <p class="lead">首页集中展示收入、纯利润、每日走势、销量排行和利润排行，方便你快速看清经营变化。</p>
    </div>
</section>

<section class="cards cards-six">
    <article class="card metric">
        <span>当天收入</span>
        <strong>@FormatCurrency(todayIncome)</strong>
    </article>
    <article class="card metric">
        <span>7 天收入</span>
        <strong>@FormatCurrency(sevenDayIncome)</strong>
    </article>
    <article class="card metric">
        <span>30 天收入</span>
        <strong>@FormatCurrency(thirtyDayIncome)</strong>
    </article>
    <article class="card metric">
        <span>当天纯利润</span>
        <strong>@FormatCurrency(todayProfit)</strong>
    </article>
    <article class="card metric">
        <span>7 天纯利润</span>
        <strong>@FormatCurrency(sevenDayProfit)</strong>
    </article>
    <article class="card metric">
        <span>30 天纯利润</span>
        <strong>@FormatCurrency(thirtyDayProfit)</strong>
    </article>
</section>

<section class="panel-grid">
    <section class="panel sales-chart-panel">
        <div class="panel-head">
            <div>
                <h2>每日销售额</h2>
                <span>最近 30 天销售额折线图</span>
            </div>
            <strong class="chart-summary">峰值 @FormatCurrency(salesChart.MaxAmount)</strong>
        </div>

        @if (!salesChart.HasData)
        {
            <p class="empty-state">最近 30 天暂无销售数据。</p>
        }
        else
        {
            <div class="sales-chart">
                <svg viewBox="0 0 720 260" class="sales-chart-svg" role="img" aria-label="最近30天每日销售额折线图">
                    <polyline class="chart-grid-line" points="48,24 48,220 688,220" />
                    @foreach (var guide in salesChart.Guides)
                    {
                        <line class="chart-guide" x1="48" y1="@FormatNumber(guide.Y)" x2="688" y2="@FormatNumber(guide.Y)"></line>
                        <svg:text class="chart-axis-label" x="8" y="@FormatNumber(guide.Y + 4m)">@guide.AmountText</svg:text>
                    }
                    <polygon class="chart-area" points="@salesChart.AreaPoints" />
                    <polyline class="chart-line" points="@salesChart.LinePoints" />
                    @foreach (var point in salesChart.Dots)
                    {
                        <circle class="chart-dot" cx="@FormatNumber(point.X)" cy="@FormatNumber(point.Y)" r="4">
                            <title>@point.Label</title>
                        </circle>
                    }
                    @foreach (var label in salesChart.DateLabels)
                    {
                        <svg:text class="chart-axis-label" x="@FormatNumber(label.X)" y="246" text-anchor="@label.Anchor">@label.Text</svg:text>
                    }
                </svg>
            </div>
        }
    </section>

    <section class="panel sales-chart-panel">
        <div class="panel-head">
            <div>
                <h2>每日纯利润</h2>
                <span>最近 30 天纯利润折线图</span>
            </div>
            <strong class="chart-summary">峰值 @FormatCurrency(profitChart.MaxAmount)</strong>
        </div>

        @if (!profitChart.HasData)
        {
            <p class="empty-state">最近 30 天暂无利润数据。</p>
        }
        else
        {
            <div class="sales-chart">
                <svg viewBox="0 0 720 260" class="sales-chart-svg" role="img" aria-label="最近30天每日纯利润折线图">
                    <polyline class="chart-grid-line" points="48,24 48,220 688,220" />
                    @foreach (var guide in profitChart.Guides)
                    {
                        <line class="chart-guide" x1="48" y1="@FormatNumber(guide.Y)" x2="688" y2="@FormatNumber(guide.Y)"></line>
                        <svg:text class="chart-axis-label" x="8" y="@FormatNumber(guide.Y + 4m)">@guide.AmountText</svg:text>
                    }
                    <polygon class="chart-area profit-chart-area" points="@profitChart.AreaPoints" />
                    <polyline class="chart-line profit-chart-line" points="@profitChart.LinePoints" />
                    @foreach (var point in profitChart.Dots)
                    {
                        <circle class="chart-dot profit-chart-dot" cx="@FormatNumber(point.X)" cy="@FormatNumber(point.Y)" r="4">
                            <title>@point.Label</title>
                        </circle>
                    }
                    @foreach (var label in profitChart.DateLabels)
                    {
                        <svg:text class="chart-axis-label" x="@FormatNumber(label.X)" y="246" text-anchor="@label.Anchor">@label.Text</svg:text>
                    }
                </svg>
            </div>
        }
    </section>
</section>

<section class="panel-grid">
    <article class="panel">
        <div class="panel-head">
            <div>
                <h2>近 7 天商品销量排行</h2>
                <span>按售出数量排序</span>
            </div>
        </div>

        @if (sevenDayTopProducts.Count == 0)
        {
            <p class="empty-state">近 7 天暂无销售数据。</p>
        }
        else
        {
            <ol class="ranking-list">
                @foreach (var item in sevenDayTopProducts.Select((value, index) => new { value, index }))
                {
                    <li class="ranking-item">
                        <div class="ranking-meta">
                            <span class="rank-badge">#@(item.index + 1)</span>
                            <strong>@item.value.ProductName</strong>
                        </div>
                        <span class="ranking-value">@item.value.Quantity @item.value.Unit</span>
                    </li>
                }
            </ol>
        }
    </article>

    <article class="panel">
        <div class="panel-head">
            <div>
                <h2>近 30 天商品销量排行</h2>
                <span>按售出数量排序</span>
            </div>
        </div>

        @if (thirtyDayTopProducts.Count == 0)
        {
            <p class="empty-state">近 30 天暂无销售数据。</p>
        }
        else
        {
            <ol class="ranking-list">
                @foreach (var item in thirtyDayTopProducts.Select((value, index) => new { value, index }))
                {
                    <li class="ranking-item">
                        <div class="ranking-meta">
                            <span class="rank-badge">#@(item.index + 1)</span>
                            <strong>@item.value.ProductName</strong>
                        </div>
                        <span class="ranking-value">@item.value.Quantity @item.value.Unit</span>
                    </li>
                }
            </ol>
        }
    </article>
</section>

<section class="panel-grid">
    <article class="panel">
        <div class="panel-head">
            <div>
